<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ExoPlayer view — para streams directos -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:focusable="true"
        app:show_subtitle_button="true"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>





    <!-- Barra superior con info del servidor y botones -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#AA000000"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Volver"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary_focus"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tv_server_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_server_lang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white_40"
                android:textSize="11sp"/>

        </LinearLayout>

        <Button
            android:id="@+id/btn_change_server"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Cambiar servidor"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_button_secondary_focus"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Buffering -->
    <LinearLayout
        android:id="@+id/layout_buffering"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/accent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando..."
            android:textColor="@color/white_70"
            android:textSize="14sp"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

    <!-- Error -->
    <LinearLayout
        android:id="@+id/layout_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@drawable/bg_card_dark"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_back_error"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Volver"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_secondary_focus"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:focusable="true"/>

    </LinearLayout>

    <!-- Selector de servidor -->
    <FrameLayout
        android:id="@+id/layout_server_selector"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cambiar servidor"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:id="@+id/layout_servers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_cancel_server"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:text="Cancelar"
                android:textColor="@color/white_70"
                android:background="@drawable/bg_focusable_item"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="12dp"
                android:focusable="true"/>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>